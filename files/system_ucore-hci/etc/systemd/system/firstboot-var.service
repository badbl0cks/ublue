[Unit]
Description=var - First Boot Setup
ConditionPathExists=!/var/.firstboot
Before=network.target
After=network-pre.target

[Service]
StandardOutput=journal+console
Type=oneshot
ExecStart=/usr/bin/firstboot-var
ExecStart=/usr/bin/systemctl disable firstboot-var.service
Restart=on-failure
RestartSec=1

[Install]
WantedBy=multi-user.target
