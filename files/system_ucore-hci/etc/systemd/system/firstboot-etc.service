[Unit]
Description=etc - First Boot Setup
ConditionPathExists=!/etc/.firstboot
Before=network.target
After=network-pre.target

[Service]
StandardOutput=journal+console
Type=oneshot
ExecStart=/usr/bin/firstboot-etc
ExecStart=/usr/bin/systemctl disable firstboot-etc.service
Restart=on-failure
RestartSec=1

[Install]
WantedBy=multi-user.target
