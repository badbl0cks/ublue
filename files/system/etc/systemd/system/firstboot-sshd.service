[Unit]
Description=sshd - First Boot Setup
ConditionPathExists=/etc/ssh/.firstboot
Before=sshd.service

[Service]
StandardOutput=journal+console
Type=oneshot
ExecStart=/usr/bin/firstboot-sshd
ExecStart=/usr/bin/systemctl disable firstboot-sshd.service
Restart=on-failure
RestartSec=1

[Install]
WantedBy=multi-user.target
