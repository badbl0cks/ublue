#!/usr/bin/env bash
set -euo pipefail

WD="/etc/wireguard"
cd "${WD}"

if [[ -f "${WD}/.firstboot_%i" ]]; then
    echo "First boot detected. Running..."

    firewall-cmd --add-service=wireguard --permanent > /dev/null
    firewall-cmd --reload > /dev/null

    keys=("ADDRESS" "PRIVATE_KEY" "PUBLIC_KEY" "ALLOWED_IPS" "ENDPOINT" "PRESHARED_KEY")
    config_wg="${WD}/wg0.conf"

    set -a
    source "${WD}/config.env" || echo "No config.env found, aborting..." && exit 1
    set +a

    for env_key in "${keys[@]}"; do
        value="${!env_key:-}"
        sed -i -e "s|{{${env_key}}}|${value}|g" "${config_wg}"
    done

    rm -f "${WD}/.firstboot" "${WD}/config.env"
    echo "First boot script completed."
else
    echo "First boot script already run (missing .firstboot file in ${WD}). Skipping..."

fi
